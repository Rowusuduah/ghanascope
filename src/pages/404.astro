---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found"
  description="The page you're looking for doesn't exist yet. Browse our Ghana business analysis."
>
  <div style="max-width:600px;margin:0 auto;padding:6rem 1.5rem;text-align:center;">
    <div style="font-size:4rem;font-weight:800;color:#D4A843;margin-bottom:0.5rem;">404</div>
    <h1 style="font-size:1.5rem;margin-bottom:0.75rem;">Page Not Found</h1>
    <p style="color:#6b7280;margin-bottom:2rem;line-height:1.6;">This analysis hasn't been published yet, or the URL is incorrect. We're continuously adding new Ghana business intelligence.</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="/" style="display:inline-block;background:#1a1a2e;color:white;padding:0.75rem 1.5rem;border-radius:8px;font-weight:600;text-decoration:none;">Go Home</a>
      <a href="/analysis" style="display:inline-block;background:white;color:#1a1a2e;padding:0.75rem 1.5rem;border-radius:8px;font-weight:600;border:1px solid #e5e7eb;text-decoration:none;">Browse Analysis</a>
    </div>
  </div>
</Base>

---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found"
  description="The page you're looking for doesn't exist yet. Browse our Ghana business analysis."
>
  <div class="hero" style="min-height:60vh;display:flex;align-items:center;justify-content:center;">
    <div class="hero-inner">
      <div class="error-code">404</div>
      <h1>Page Not Found</h1>
      <p>This analysis has not been published yet, or the URL is incorrect. We are continuously adding new Ghana business intelligence through the v3.0 pipeline.</p>
      <div class="error-links">
        <a href="/" class="error-link">Home</a>
        <a href="/analysis" class="error-link">Analysis</a>
        <a href="/sectors" class="error-link">Sectors</a>
        <a href="/diaspora" class="error-link">Diaspora</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .error-code {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    color: var(--gold, #C9A84C);
    font-family: var(--font-mono, monospace);
    letter-spacing: -0.04em;
    margin-bottom: 0.5rem;
  }
  .error-links {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .error-link {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.6) !important;
    font-size: 0.82rem;
    font-weight: 500;
    transition: color 0.15s, border-color 0.15s;
  }
  .error-link:hover {
    color: #fff !important;
    border-color: rgba(255, 255, 255, 0.3);
  }
</style>

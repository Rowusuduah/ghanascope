      <tr><td>Transport (farm to factory)</td><td>6,000</td><td>$547</td><td>Post-Hormuz diesel pricing</td></tr>
      <tr><td>Packaging and storage</td><td>4,500</td><td>$410</td><td>50kg bags, warehouse rent</td></tr>
      <tr><td>Maintenance and overhead</td><td>3,500</td><td>$319</td><td>Equipment, admin, permits</td></tr>

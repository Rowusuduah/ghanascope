      <tr><td>Pharmaceuticals</td><td>Food and Drugs Authority</td><td>FDA manufacturing license</td><td>3 to 6 months</td><td>GHS 5,000 to 20,000</td></tr>
      <tr><td>Telecoms/Fintech</td><td>National Communications Authority</td><td>NCA license</td><td>2 to 6 months</td><td>GHS 10,000 to 100,000+</td></tr>
      <tr><td>Banking/Finance</td><td>Bank of Ghana</td><td>BoG license</td><td>6 to 12 months</td><td>Varies widely</td></tr>
      <tr><td>Construction</td><td>Various (EPA, local assembly)</td><td>Building/operating permits</td><td>2 to 6 months</td><td>GHS 5,000 to 30,000</td></tr>
      <tr><td>Manufacturing</td><td>EPA + Ghana Standards Authority</td><td>Environmental + quality permits</td><td>2 to 4 months</td><td>GHS 3,000 to 15,000</td></tr>

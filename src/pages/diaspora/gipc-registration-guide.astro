      <tr><td>TIN registration (GRA)</td><td>1 to 2 days</td><td>1 to 2 weeks</td><td>System downtime, verification delays</td></tr>
      <tr><td>GIPC registration</td><td>5 business days</td><td>2 to 6 weeks</td><td>Incomplete applications, capital proof issues, resubmissions</td></tr>
      <tr><td>Sector permits</td><td>Varies</td><td>1 to 12 months</td><td>Site inspections, committee reviews, inter-agency coordination</td></tr>
      <tr><td>Bank account opening</td><td>1 to 2 days</td><td>1 to 4 weeks</td><td>Enhanced due diligence for foreign-owned entities, compliance checks</td></tr>
      <tr><td><strong>Total (simple business)</strong></td><td><strong>2 to 4 weeks</strong></td><td><strong>2 to 4 months</strong></td><td></td></tr>

  <div class="container">
    <div class="stats-bar">
      <div class="stat-card positive">
        <div class="value">6.0%</div>
        <div class="label">GDP Growth Rate (2025)</div>
      </div>
      <div class="stat-card negative">
        <div class="value">23.1%</div>
        <div class="label">Inflation (CPI)</div>

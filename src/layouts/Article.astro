---
import Base from './Base.astro';
import HeroImage from '../components/HeroImage.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AuthorCard from '../components/AuthorCard.astro';
import TableOfContents from '../components/TableOfContents.astro';
import SocialShare from '../components/SocialShare.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import RelatedArticles from '../components/RelatedArticles.astro';

interface Heading {
  text: string;
  id: string;
}

interface RelatedItem {
  href: string;
  title: string;
  description: string;
  tag?: string;
  tagType?: 'risk' | 'policy' | 'opportunity' | 'guide' | 'scenario' | 'data';
}

interface Props {
  title: string;
  description: string;
  keywords?: string;
  publishedDate: string;
  heroImage: ImageMetadata;
  heroAlt: string;
  heroCredit?: string;
  heroCreditSource?: string;
  heroCreditUrl?: string;
  tag?: string;
  tagType?: 'risk' | 'policy' | 'opportunity' | 'guide' | 'scenario' | 'data';
  section?: { label: string; href: string };
  headings?: Heading[];
  relatedArticles?: RelatedItem[];
  wordCount?: number;
  confidence?: string;
  source?: string;
}

const {
  title,
  description,
  keywords,
  publishedDate,
  heroImage,
  heroAlt,
  heroCredit,
  heroCreditSource,
  heroCreditUrl,
  tag,
  tagType = 'opportunity',
  section = { label: 'Analysis', href: '/analysis' },
  headings = [],
  relatedArticles = [],
  wordCount = 1500,
  confidence,
  source,
} = Astro.props;

const tagColorMap: Record<string, string> = {
  risk: 'risk',
  policy: 'policy',
  opportunity: 'data',
  guide: 'guide',
  scenario: 'scenario',
  data: 'data',
};

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<Base
  title={title}
  description={description}
  keywords={keywords}
  article={true}
  publishedDate={publishedDate}
>
  <Breadcrumbs items={[
    { label: 'Home', href: '/' },
    { label: section.label, href: section.href },
    { label: title },
  ]} />

  <HeroImage
    image={heroImage}
    alt={heroAlt}
    credit={heroCredit}
    creditSource={heroCreditSource}
    creditUrl={heroCreditUrl}
    height={440}
  >
    {tag && <span class={`card-tag ${tagColorMap[tagType] || ''}`}>{tag}</span>}
    <h1 class="article-hero__title">{title}</h1>
    <div class="article-hero__meta">
      {confidence && <span>Confidence: {confidence}</span>}
      {source && <span>{source}</span>}
    </div>
  </HeroImage>

  <div class="article-layout">
    <article class="article-layout__main">
      <AuthorCard publishedDate={publishedDate} wordCount={wordCount} />
      <div class="article-body">
        <slot />
      </div>
      <SocialShare title={title} url={canonicalUrl} />
    </article>

    {headings.length > 0 && (
      <div class="article-layout__sidebar">
        <TableOfContents headings={headings} />
      </div>
    )}
  </div>

  <RelatedArticles articles={relatedArticles} />
  <NewsletterSignup />
</Base>

<style>
  .article-hero__title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin-bottom: 0.5rem;
    max-width: 800px;
  }
  .article-hero__meta {
    display: flex;
    gap: 1rem;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.5);
  }
  .article-layout {
    max-width: var(--max-width, 1080px);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0;
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 3rem;
    align-items: start;
  }
  .article-layout__main {
    min-width: 0;
  }
  .article-layout__sidebar {
    padding-top: 1rem;
  }
  @media (max-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .article-layout__sidebar {
      order: -1;
      padding-top: 0;
    }
    .article-hero__title {
      font-size: 1.6rem;
    }
  }
</style>

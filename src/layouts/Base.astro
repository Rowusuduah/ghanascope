---
interface Props {
  title: string;
  description: string;
  keywords?: string;
  article?: boolean;
  publishedDate?: string;
  image?: string;
}

const {
  title,
  description,
  keywords = 'Ghana business, diaspora investment, Ghana economy, Ghana opportunities, Africa investment',
  article = false,
  publishedDate,
  image = '/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === 'GhanaScope' ? title : `${title} | GhanaScope`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Primary SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="author" content="GhanaScope" />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={article ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:site_name" content="GhanaScope" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site)} />

  {article && publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )}

  <!-- JSON-LD Structured Data -->
  {article ? (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "datePublished": publishedDate,
      "author": {
        "@type": "Organization",
        "name": "GhanaScope"
      },
      "publisher": {
        "@type": "Organization",
        "name": "GhanaScope",
        "url": "https://ghanascope.com"
      },
      "mainEntityOfPage": canonicalURL.toString()
    })} />
  ) : (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "GhanaScope",
      "description": "Honest, data-driven Ghana business intelligence for diaspora investors and founders",
      "url": "https://ghanascope.com"
    })} />
  )}

  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="logo">GhanaScope</a>
      <div class="nav-links">
        <a href="/analysis">Analysis</a>
        <a href="/sectors">Sectors</a>
        <a href="/risks">Risk Watch</a>
        <a href="/diaspora">Diaspora Guide</a>
        <a href="/about">About</a>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-col">
        <h3>GhanaScope</h3>
        <p>Honest, evidence-grounded Ghana business intelligence. No hype. No generic Africa-rising narratives. Just truth.</p>
      </div>
      <div class="footer-col">
        <h3>Analysis</h3>
        <a href="/analysis">All Reports</a>
        <a href="/sectors">Sector Rankings</a>
        <a href="/risks">Risk Watch</a>
        <a href="/diaspora">Diaspora Guide</a>
      </div>
      <div class="footer-col">
        <h3>Topics</h3>
        <a href="/topics/gdp">GDP & Growth</a>
        <a href="/topics/cedi">Cedi & Currency</a>
        <a href="/topics/infrastructure">Infrastructure</a>
        <a href="/topics/policy">Policy & Regulation</a>
      </div>
      <div class="footer-col">
        <h3>Connect</h3>
        <a href="https://github.com/Rowusuduah/ghanascope">GitHub</a>
        <a href="/about">About Us</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 GhanaScope. Built by Richmond Owusu Duah.</p>
    </div>
  </footer>
</body>
</html>

---
interface Props {
  ghanaians: string;
  investors: string;
  diaspora: string;
  entrepreneurs: string;
}

const { ghanaians, investors, diaspora, entrepreneurs } = Astro.props;
---

<section class="audience-breakdown reveal" id="what-this-means">
  <h2>What This Means for You</h2>
  <div class="audience-grid">
    <div class="audience-card audience-ghanaians">
      <div class="audience-card__header">
        <h3>For Ghanaians</h3>
      </div>
      <div class="audience-card__body" set:html={ghanaians} />
    </div>

    <div class="audience-card audience-investors">
      <div class="audience-card__header">
        <h3>For Investors</h3>
      </div>
      <div class="audience-card__body" set:html={investors} />
    </div>

    <div class="audience-card audience-diaspora">
      <div class="audience-card__header">
        <h3>For the Diaspora</h3>
      </div>
      <div class="audience-card__body" set:html={diaspora} />
    </div>

    <div class="audience-card audience-entrepreneurs">
      <div class="audience-card__header">
        <h3>For Entrepreneurs</h3>
      </div>
      <div class="audience-card__body" set:html={entrepreneurs} />
    </div>
  </div>
</section>

<style>
  .audience-breakdown {
    max-width: var(--max-width, 1080px);
    margin: 2.5rem auto;
    padding: 0 1.5rem;
  }
  .audience-breakdown h2 {
    font-family: var(--font-sans, 'Inter', sans-serif);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--ink, #0F1419);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border, #E4E7EC);
    border: 1px solid var(--border, #E4E7EC);
  }
  .audience-card {
    background: var(--bg, #ffffff);
    padding: 1.5rem;
    border-left: 3px solid var(--border, #E4E7EC);
  }
  .audience-ghanaians { border-left-color: var(--green, #2E7D32); }
  .audience-investors { border-left-color: var(--gold, #C9A84C); }
  .audience-diaspora { border-left-color: var(--blue, #1565C0); }
  .audience-entrepreneurs { border-left-color: var(--red, #C62828); }

  .audience-card__header h3 {
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.6rem;
  }
  .audience-ghanaians h3 { color: var(--green, #2E7D32); }
  .audience-investors h3 { color: var(--gold, #C9A84C); }
  .audience-diaspora h3 { color: var(--blue, #1565C0); }
  .audience-entrepreneurs h3 { color: var(--red, #C62828); }

  .audience-card__body {
    font-size: 0.88rem;
    color: var(--text-secondary, #475467);
    line-height: 1.6;
  }
  .audience-card__body :global(p) {
    margin-bottom: 0.5rem;
  }
  .audience-card__body :global(strong) {
    color: var(--ink, #0F1419);
  }
  .audience-card__body :global(ul) {
    padding-left: 1.2rem;
    margin-top: 0.5rem;
  }
  .audience-card__body :global(li) {
    margin-bottom: 0.25rem;
  }
  @media (max-width: 768px) {
    .audience-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

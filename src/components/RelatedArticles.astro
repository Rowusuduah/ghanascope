---
interface RelatedItem {
  href: string;
  title: string;
  description: string;
  tag?: string;
  tagType?: 'risk' | 'policy' | 'opportunity' | 'guide' | 'scenario' | 'data';
}

interface Props {
  articles: RelatedItem[];
}

const { articles } = Astro.props;
---

{articles.length > 0 && (
  <section class="related">
    <div class="related__label">Continue Reading</div>
    <div class="related__list">
      {articles.map((a) => {
        const tagClass = `card-tag ${a.tagType || ''}`;
        return (
          <a href={a.href} class="related__item">
            {a.tag && <span class={tagClass}>{a.tag}</span>}
            <h4>{a.title}</h4>
            <p>{a.description}</p>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .related {
    max-width: var(--max-width, 1080px);
    margin: 0 auto;
    padding: 2.5rem 1.5rem 0;
    border-top: 1px solid var(--border, #E4E7EC);
  }
  .related__label {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary, #98A2B3);
    margin-bottom: 1rem;
  }
  .related__list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    background: var(--border, #E4E7EC);
    border: 1px solid var(--border, #E4E7EC);
  }
  .related__item {
    background: var(--bg, #fff);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .related__item:hover {
    background: var(--surface, #F9FAFB);
  }
  .related__item h4 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    color: var(--ink, #0F1419);
    letter-spacing: -0.01em;
  }
  .related__item p {
    font-size: 0.82rem;
    color: var(--text-secondary, #475467);
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .related__list { grid-template-columns: 1fr; }
  }
</style>

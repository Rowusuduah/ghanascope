---
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  alt: string;
  credit?: string;
  creditSource?: string;
  creditUrl?: string;
  height?: number;
}

const {
  image,
  alt,
  credit,
  creditSource = 'Unsplash',
  creditUrl,
  height = 440,
} = Astro.props;
---

<div class="hero-image" style={`--hero-height: ${height}px`}>
  <Image
    src={image}
    alt={alt}
    width={1600}
    height={height}
    class="hero-image__img"
    loading="eager"
    format="webp"
  />
  <div class="hero-image__overlay"></div>
  <div class="hero-image__content">
    <slot />
  </div>
  {credit && (
    <div class="hero-image__credit">
      Photo by {creditUrl ? <a href={creditUrl} target="_blank" rel="noopener">{credit}</a> : credit}
      {creditSource && <span> on {creditSource}</span>}
    </div>
  )}
</div>

<style>
  .hero-image {
    position: relative;
    width: 100%;
    height: var(--hero-height);
    overflow: hidden;
  }
  .hero-image__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-image__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(15, 20, 25, 0.35) 0%,
      rgba(15, 20, 25, 0.55) 50%,
      rgba(15, 20, 25, 0.85) 100%
    );
  }
  .hero-image__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 3rem 2rem;
    max-width: 1080px;
    margin: 0 auto;
    left: 0;
    right: 0;
    color: white;
  }
  .hero-image__credit {
    position: absolute;
    bottom: 0.75rem;
    right: 1rem;
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.02em;
  }
  .hero-image__credit a {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  @media (max-width: 768px) {
    .hero-image { height: 380px; }
    .hero-image__content { padding: 2rem 1.25rem; }
  }
  @media (max-width: 480px) {
    .hero-image { height: 340px; }
  }
</style>

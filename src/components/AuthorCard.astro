---
interface Props {
  author?: string;
  publishedDate: string;
  wordCount: number;
}

const { author = 'GhanaScope Intelligence', publishedDate, wordCount } = Astro.props;

const readingTime = Math.max(1, Math.ceil(wordCount / 220));
const formattedDate = new Date(publishedDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="author-card">
  <div class="author-card__avatar">
    <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
      <rect width="36" height="36" fill="#C9A84C"/>
      <path d="M18 10L26 18L18 26L10 18Z" fill="#0F1419"/>
    </svg>
  </div>
  <div class="author-card__info">
    <div class="author-card__name">{author}</div>
    <div class="author-card__meta">
      <time datetime={publishedDate}>{formattedDate}</time>
      <span class="author-card__dot">&middot;</span>
      <span>{readingTime} min read</span>
    </div>
  </div>
</div>

<style>
  .author-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border, #E4E7EC);
    margin-bottom: 1.5rem;
  }
  .author-card__name {
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--ink, #0F1419);
  }
  .author-card__meta {
    font-size: 0.78rem;
    color: var(--text-tertiary, #98A2B3);
    display: flex;
    gap: 0.4rem;
  }
  .author-card__dot {
    color: var(--border, #E4E7EC);
  }
</style>

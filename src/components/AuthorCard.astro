---
interface Props {
  author?: string;
  publishedDate: string;
  wordCount: number;
}

const { author = 'GhanaScope Intelligence', publishedDate, wordCount } = Astro.props;

const readingTime = Math.max(1, Math.ceil(wordCount / 220));
const formattedDate = new Date(publishedDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="author-card">
  <div class="author-card__avatar">
    <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
      <rect width="36" height="36" rx="8" fill="#1a1a2e"/>
      <text x="18" y="23" text-anchor="middle" font-family="sans-serif" font-weight="700" font-size="14" fill="#D4A843">GS</text>
    </svg>
  </div>
  <div class="author-card__info">
    <div class="author-card__name">{author}</div>
    <div class="author-card__meta">
      <time datetime={publishedDate}>{formattedDate}</time>
      <span class="author-card__dot">·</span>
      <span>{readingTime} min read</span>
    </div>
  </div>
</div>

<style>
  .author-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 0;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 1.5rem;
  }
  .author-card__name {
    font-weight: 600;
    font-size: 0.95rem;
    color: #1a1a2e;
  }
  .author-card__meta {
    font-size: 0.82rem;
    color: #6b7280;
    display: flex;
    gap: 0.4rem;
  }
  .author-card__dot {
    color: #d1d5db;
  }
</style>

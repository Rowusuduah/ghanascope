---
interface Heading {
  text: string;
  id: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <aside class="toc" aria-label="Table of contents">
    <div class="toc__title">In this article</div>
    <nav>
      <ul>
        {headings.map((h) => (
          <li><a href={`#${h.id}`}>{h.text}</a></li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<style>
  .toc {
    position: sticky;
    top: 68px;
    align-self: start;
    padding: 1.25rem;
    background: var(--surface, #F9FAFB);
    border: 1px solid var(--border, #E4E7EC);
  }
  .toc__title {
    font-weight: 600;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary, #98A2B3);
    margin-bottom: 0.75rem;
  }
  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc li {
    margin-bottom: 0.35rem;
  }
  .toc a {
    font-size: 0.82rem;
    color: var(--text-secondary, #475467);
    text-decoration: none;
    line-height: 1.4;
    display: block;
    padding: 0.15rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    transition: color 0.15s, border-color 0.15s;
  }
  .toc a:hover {
    color: var(--ink, #0F1419);
    border-left-color: var(--gold, #C9A84C);
  }
  @media (max-width: 1024px) {
    .toc {
      position: static;
      margin-bottom: 1.5rem;
    }
  }
</style>

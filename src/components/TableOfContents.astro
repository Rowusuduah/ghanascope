---
interface Heading {
  text: string;
  id: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <aside class="toc" aria-label="Table of contents">
    <div class="toc__title">In this article</div>
    <nav>
      <ul>
        {headings.map((h) => (
          <li><a href={`#${h.id}`}>{h.text}</a></li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<style>
  .toc {
    position: sticky;
    top: 80px;
    align-self: start;
    padding: 1.25rem;
    background: #f9fafb;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
  }
  .toc__title {
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
    margin-bottom: 0.75rem;
  }
  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc li {
    margin-bottom: 0.4rem;
  }
  .toc a {
    font-size: 0.85rem;
    color: #374151;
    text-decoration: none;
    line-height: 1.4;
    display: block;
    padding: 0.15rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    transition: all 0.15s;
  }
  .toc a:hover {
    color: #006B3F;
    border-left-color: #006B3F;
  }
  @media (max-width: 1024px) {
    .toc {
      position: static;
      margin-bottom: 1.5rem;
    }
  }
</style>
